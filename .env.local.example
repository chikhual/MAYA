# Supabase - crear en .env.local con tus valores
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Resend (para correos desde el frontend o API routes - las Edge Functions usan sus propios secrets)
RESEND_API_KEY=re_tu_api_key

# Email del administrador (prellena el campo de prueba en Configuración)
NEXT_PUBLIC_ADMIN_EMAIL=admin@tudominio.com

# URL del sitio (para Fichas de Bienvenida y enlaces; ej. https://maya-rotary.vercel.app)
# NEXT_PUBLIC_APP_URL=https://maya-rotary.vercel.app

# Service Role Key (para import-socios y operaciones admin)
# Supabase > Settings > API > service_role (secret)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Conexión directa PostgreSQL (para migraciones: npm run migrate-mote)
# Supabase > Settings > Database > Connection string (URI)
# DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@xxx.pooler.supabase.com:6543/postgres
